# ═══════════════════════════════════════════════════════
# Email Agent — Environment Variables
# کپی این فایل به .env و مقادیر را وارد کنید
# ═══════════════════════════════════════════════════════

# ─────────────────────────────
# App
# ─────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ─────────────────────────────
# امنیت (اجباری — تغییر دهید!)
# ─────────────────────────────
# تولید: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS_RANDOM_KEY_HERE_000000000000000000000000000000

# JWT برای Web Dashboard (اگر فعال باشد)
JWT_SECRET=CHANGE_ME_RANDOM_JWT_SECRET
JWT_EXPIRES_IN=7d

# ─────────────────────────────
# Database
# ─────────────────────────────
# Phase 0/1 — SQLite
DATABASE_URL=sqlite:./data/agent.db

# Phase 2 — PostgreSQL (uncomment when ready)
# DATABASE_URL=postgresql://agent:password@localhost:5432/emailagent
# REDIS_URL=redis://:password@localhost:6379
# DB_PASSWORD=your_strong_password
# REDIS_PASSWORD=your_redis_password

# ─────────────────────────────
# Telegram Bot
# ─────────────────────────────
# ساخت Bot: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Telegram ID کاربر اصلی (امنیت: فقط این ID می‌تواند با bot ارتباط بگیرد)
# پیدا کردن ID: https://t.me/userinfobot
TELEGRAM_ALLOWED_USERS=123456789

# ─────────────────────────────
# LLM (پیش‌فرض)
# ─────────────────────────────
# کاربر می‌تواند از طریق تلگرام تغییر دهد
# اما اگر هنوز تنظیم نکرده، از این استفاده می‌شود

LLM_PROVIDER=openrouter         # openai|gemini|claude|openrouter|ollama|custom
LLM_API_KEY=sk-or-v1-...        # API Key
LLM_MODEL=google/gemini-flash-1.5  # مدل پیش‌فرض
LLM_BASE_URL=                   # فقط برای Ollama: http://localhost:11434

# Fallback (اگر Provider اصلی خطا داد)
LLM_FALLBACK_PROVIDER=ollama
LLM_FALLBACK_MODEL=llama3.2

# ─────────────────────────────
# Email Ingestion
# ─────────────────────────────

# روش ۱: SMTP Server (برای Forward)
SMTP_HOST=0.0.0.0
SMTP_PORT=25
SMTP_FORWARD_ADDRESS=agent@yourdomain.com  # ایمیلی که Forward می‌شود به آن
# SMTP_ALLOWED_IPS اجباری در production — فقط IP‌های مورد اعتماد (کاما جدا)
# مثال: SMTP_ALLOWED_IPS=127.0.0.1,10.0.0.5
SMTP_ALLOWED_IPS=127.0.0.1

# روش ۲: Gmail OAuth (Phase 1)
GMAIL_CLIENT_ID=your_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_client_secret
GMAIL_REDIRECT_URI=http://localhost:3000/auth/gmail/callback

# Google Cloud Pub/Sub (برای Gmail Webhook)
GOOGLE_CLOUD_PROJECT_ID=your_project_id
GMAIL_PUBSUB_TOPIC=projects/your_project/topics/gmail-push
GOOGLE_APPLICATION_CREDENTIALS=./config/google-service-account.json

# روش ۳: IMAP Polling
# کاربر از طریق تلگرام تنظیم می‌کند

# ─────────────────────────────
# Web Dashboard (Phase 2)
# ─────────────────────────────
WEB_ENABLED=false               # true برای فعال کردن
WEB_PORT=3000
WEB_SESSION_SECRET=CHANGE_ME_SESSION_SECRET

# CORS (آدرس‌های مجاز)
CORS_ORIGINS=http://localhost:3000

# ─────────────────────────────
# Email Sending
# ─────────────────────────────
# برای ارسال پاسخ‌ها (SMTP outgoing)
OUTGOING_SMTP_HOST=smtp.gmail.com
OUTGOING_SMTP_PORT=587
OUTGOING_SMTP_SECURE=true
OUTGOING_SMTP_USER=your@gmail.com
OUTGOING_SMTP_PASS=your_app_password  # Gmail App Password (نه رمز اصلی)

# ─────────────────────────────
# Logging
# ─────────────────────────────
LOG_LEVEL=info                  # debug|info|warn|error
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# ─────────────────────────────
# Features (toggle)
# ─────────────────────────────
FEATURE_MULTI_ACCOUNT=true
FEATURE_TEMPLATES=true
FEATURE_SCHEDULING=true
FEATURE_FOLLOW_UPS=true
FEATURE_ANALYTICS=true
FEATURE_PLUGINS=false           # در Phase 2 فعال شود

# ─────────────────────────────
# Data Retention
# ─────────────────────────────
DEFAULT_RETENTION_DAYS=30       # ایمیل‌ها بعد از چند روز پاک شوند
MAX_RETENTION_DAYS=365

# ─────────────────────────────
# Rate Limiting
# ─────────────────────────────
RATE_LIMIT_LLM_PER_MIN=60
RATE_LIMIT_EMAIL_SEND_PER_MIN=20
RATE_LIMIT_API_PER_MIN=100
