{
  "name": "email-agent",
  "version": "0.1.0",
  "description": "دستیار هوشمند ایمیل مبتنی بر LLM",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "dev:frontend": "vite",
    "build": "tsc && vite build",
    "start": "node --loader ts-node/esm src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:export": "tsx scripts/export.ts",
    "db:import": "tsx scripts/import.ts",
    "setup": "bash scripts/setup.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.21.1",
    "@google/generative-ai": "^0.3.1",
    "better-sqlite3": "^9.4.3",
    "bull": "^4.12.2",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "googleapis": "^140.0.0",
    "helmet": "^7.1.0",
    "imap": "^0.8.19",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.7.0",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "nodemailer": "^6.9.13",
    "openai": "^4.47.1",
    "pg": "^8.11.5",
    "redis": "^4.6.14",
    "smtp-server": "^3.13.4",
    "telegraf": "^4.16.3",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "ws": "^8.17.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.8.1",
    "@preact/signals": "^1.3.0",
    "@types/better-sqlite3": "^7.6.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/imap": "^0.8.40",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/mailparser": "^3.4.4",
    "@types/node": "^20.12.12",
    "@types/nodemailer": "^6.4.15",
    "@types/pg": "^8.11.6",
    "@types/smtp-server": "^3.5.10",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.9.0",
    "@typescript-eslint/parser": "^7.9.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.0",
    "preact": "^10.22.0",
    "preact-iso": "^2.6.2",
    "prettier": "^3.2.5",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "email",
    "ai",
    "llm",
    "telegram",
    "automation",
    "openai",
    "gemini"
  ],
  "author": "",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/email-agent.git"
  }
}
